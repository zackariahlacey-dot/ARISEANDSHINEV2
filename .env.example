# Official site URL (used for metadata, referral links, Stripe callbacks, etc.)
NEXT_PUBLIC_SITE_URL=https://ariseandshinevt.com

# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Optional: business address used as origin for travel fee (Distance Matrix API).
# If unset, defaults to 209 Porterwood Dr, Williston, Vermont.
# BUSINESS_ADDRESS=209 Porterwood Dr, Williston, Vermont

# Google Maps: used for travel fee (driving distance) and address autocomplete.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
